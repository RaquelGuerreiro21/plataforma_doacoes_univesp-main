{
  "version": 2,
  "builds": [
    {
      "src": "doacoes/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.12"
      }
    },
    {
      "src": "staticfiles_build/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles_build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "doacoes/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "doacoes.settings"
  }
}